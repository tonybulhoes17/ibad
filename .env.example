# ============================================================
# IBAD — Variáveis de Ambiente
# Copie este arquivo como .env.local e preencha com seus dados
# ============================================================

# Supabase — encontre em: Settings > API no dashboard do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...seu_anon_key

# NÃO USE service_role_key no frontend. Apenas backend/server-side se necessário.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App URL (para OAuth callbacks e redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
